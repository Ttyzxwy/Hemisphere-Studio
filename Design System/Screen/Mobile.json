{
  "Screen": {
    "breakpoint": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "text",
      "$value": "Mobile"
    },
    "width": {
      "$extensions": {
        "com.figma.scopes": [
          "WIDTH_HEIGHT"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": 375
    },
    "horizontal-padding": {
      "$extensions": {
        "com.figma.scopes": [
          "GAP"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.5}"
    },
    "vertical-padding": {
      "$extensions": {
        "com.figma.scopes": [
          "GAP"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.16}"
    },
    "content-gap": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.4}"
    },
    "content-gap-large": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.5}"
    },
    "content-padding": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.3}"
    }
  }
}
