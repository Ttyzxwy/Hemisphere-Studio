{
  "Screen": {
    "breakpoint": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "text",
      "$value": "Tablet"
    },
    "width": {
      "$extensions": {
        "com.figma.scopes": [
          "WIDTH_HEIGHT"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": 768
    },
    "horizontal-padding": {
      "$extensions": {
        "com.figma.scopes": [
          "GAP"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.6}"
    },
    "vertical-padding": {
      "$extensions": {
        "com.figma.scopes": [
          "GAP"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.20}"
    },
    "content-gap": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.5}"
    },
    "content-gap-large": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.8}"
    },
    "content-padding": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Size.4}"
    }
  }
}
